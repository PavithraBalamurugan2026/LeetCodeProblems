import java.util.*;
class Solution {
    public List<List<Integer>> permuteUnique(int[] nums) {
        List<List<Integer>> results = new ArrayList<>();
        Arrays.sort(nums);
        boolean[] used = new boolean[nums.length];
        findPermutations(nums, new ArrayList<>(), used, results);
        return results;
    }
    private void findPermutations(int[] nums, List<Integer> current, boolean[] used, List<List<Integer>> results) {
        if (current.size() == nums.length) {
            results.add(new ArrayList<>(current));
            return;
        }
        for (int i = 0; i < nums.length; i++) {
            if (used[i]) 
                continue;
            if (i > 0 && nums[i] == nums[i - 1] && !used[i - 1]) 
                continue;
            used[i] = true;
            current.add(nums[i]);
            findPermutations(nums, current, used, results);
            used[i] = false;
            current.remove(current.size() - 1);
        }
    }
}
